{
  "name" : "Just Refresh",
  "version" : "1.3",
  "description" : "One-click toggle auto-refresh",
  "options_page" : "options.html",
  "action": {},
  "permissions" : [
    "activeTab", 
    "storage"
  ],
  "commands" : {
    "toggle-refresh" : {
      "suggested_key" : {
        "default" : "Alt+R",
        "mac" : "Alt+R"
      },
      "description" : "Toggle refresh with keybind"
    }
  },
  "background" : {
    "service_worker" : "background.js"
  },
  "icons": {
    "128": "images/just_refresh128.png"
  },
  "manifest_version" : 3
}
